{
  "name": "switch4-sia-backend",
  "version": "1.0.0",
  "description": "Switch4 LLC — Sia backend API. Powers the public website chatbot, lead capture, resume upload, and JobDiva integration.",
  "main": "src/index.js",
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "start":       "node src/index.js",
    "dev":         "nodemon src/index.js",
    "db:generate": "prisma generate",
    "db:push":     "prisma db push",
    "db:migrate":  "prisma migrate deploy",
    "db:studio":   "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "openai":                     "^4.52.7",
    "express":                    "^4.19.2",
    "cors":                       "^2.8.5",
    "helmet":                     "^7.1.0",
    "dotenv":                     "^16.4.5",
    "express-rate-limit":         "^7.3.1",
    "express-validator":          "^7.1.0",
    "morgan":                     "^1.10.0",
    "winston":                    "^3.13.0",
    "multer":                     "^1.4.5-lts.1",
    "cloudinary":                 "^2.2.0",
    "multer-storage-cloudinary":  "^4.0.0",
    "nodemailer":                 "^6.9.14",
    "@prisma/client":             "^5.16.0",
    "pdf-parse":                  "^1.1.1",
    "mammoth":                    "^1.8.0",
    "uuid":                       "^10.0.0",
    "node-fetch":                 "^3.3.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma":  "^5.16.0"
  }
}
